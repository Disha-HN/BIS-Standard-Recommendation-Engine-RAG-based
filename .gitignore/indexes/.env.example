# BIS Standards Recommendation Engine — API Keys
# Copy this file to .env and fill in your keys, then:
#   Windows PowerShell:  $env:GROQ_API_KEY="your_key_here"
#   Linux/macOS:         export GROQ_API_KEY="your_key_here"

# Groq API key (primary LLM — free tier at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API key (fallback LLM — free tier at https://aistudio.google.com)
# Leave blank if you only want to use Groq
GEMINI_API_KEY=your_gemini_api_key_here
